# Required secrets (use Docker secrets or external secrets manager)
BETTER_AUTH_SECRET=your-32-character-secret-key-here
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/postgres

# Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Trusted origins for CORS
# TRUSTED_ORIGINS=http://localhost:3000,https://your-domain.com

# WhatsApp Business API Configuration
# Get these from Meta Business Manager: https://business.facebook.com/
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_API_TOKEN=your-whatsapp-api-token
